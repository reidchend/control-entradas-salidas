<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">

  <?define ProductVersion = "1.0.0" ?>
  <?define ProductCode = "*" ?>
  <?define UpgradeCode = "A1B2C3D4-E5F6-7890-ABCD-EF1234567890" ?>

  <Product
    Id="$(var.ProductCode)"
    Name="Lycoris Control"
    Language="1033"
    Version="$(var.ProductVersion)"
    Manufacturer="Reidchend"
    UpgradeCode="$(var.UpgradeCode)">

    <Package
      InstallerVersion="200"
      Compressed="yes"
      InstallScope="perMachine"
      Platform="x64"
      Manufacturer="Reidchend"
      Description="Control de Entradas y Salidas"
      Comments="Lycoris Control - Sistema de inventario offline-first"
      Keywords="inventario, control, entradas, salidas"
      />

    <Media Id="1" Cabinet="app.cab" EmbedCab="yes" />

    <!-- Detect and remove previous versions -->
    <MajorUpgrade
      DowngradeErrorMessage="A newer version of [ProductName] is already installed."
      Schedule="afterInstallInitialize"
      />

    <!-- Install directory: ProgramFiles64Folder\Reidchend\Lycoris Control -->
    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="COMPANYDIR" Name="Reidchend">
          <Directory Id="INSTALLDIR" Name="Lycoris Control">

            <!-- Component for the main files (harvested by heat) -->
            <Component Id="MainFilesComponent" Guid="{A1B2C3D4-E5F6-7890-ABCD-EF1234567891}" DiskId="1">
              <CreateFolder />
            </Component>

          </Directory>
        </Directory>
      </Directory>

      <!-- Start Menu shortcut -->
      <Directory Id="ProgramMenuFolder">
        <Directory Id="ApplicationProgramsFolder" Name="Lycoris Control">
          <Component Id="StartMenuShortcut" Guid="{A1B2C3D4-E5F6-7890-ABCD-EF1234567892}">
            <Shortcut
              Id="ApplicationStartMenuShortcut"
              Name="Lycoris Control"
              Description="Control de Entradas y Salidas"
              Target="[INSTALLDIR]Lycoris_Control.exe"
              WorkingDirectory="INSTALLDIR"
              Icon="AppIcon"
              />
            <RemoveFolder Id="RemoveApplicationProgramsFolder" On="uninstall" />
            <RegistryValue
              Root="HKCU"
              Key="Software\Reidchend\LycorisControl"
              Name="StartMenuShortcut"
              Type="integer"
              Value="1"
              KeyPath="yes"
              />
          </Component>
        </Directory>
      </Directory>

      <!-- Desktop shortcut -->
      <Directory Id="DesktopFolder">
        <Component Id="DesktopShortcut" Guid="{A1B2C3D4-E5F6-7890-ABCD-EF1234567893}">
          <Shortcut
            Id="ApplicationDesktopShortcut"
            Name="Lycoris Control"
            Description="Control de Entradas y Salidas"
            Target="[INSTALLDIR]Lycoris_Control.exe"
            WorkingDirectory="INSTALLDIR"
            Icon="AppIcon"
            />
          <RegistryValue
            Root="HKCU"
            Key="Software\Reidchend\LycorisControl"
            Name="DesktopShortcut"
            Type="integer"
            Value="1"
            KeyPath="yes"
            />
        </Component>
      </Directory>
    </Directory>

    <!-- Features -->
    <Feature Id="MainApplication" Title="Lycoris Control" Level="1" ConfigurableDirectory="INSTALLDIR" AllowAdvertise="no" Display="expand">
      <ComponentRef Id="MainFilesComponent" />
      <ComponentRef Id="StartMenuShortcut" />
      <ComponentRef Id="DesktopShortcut" />
      <ComponentGroupRef Id="HarvestedFiles" />
    </Feature>

    <!-- App icon for shortcuts -->
    <Icon Id="AppIcon" SourceFile="assets/icono.ico" />

    <!-- ARP properties (Add/Remove Programs) -->
    <Property Id="ARPPRODUCTICON" Value="AppIcon" />
    <Property Id="ARPHELPLINK" Value="https://github.com/reidchend/control-entradas-salidas" />
    <Property Id="ARPCOMMENTS" Value="Sistema de control de entradas y salidas con auto-update" />
    <Property Id="ARPCONTACT" Value="Reidchend" />

    <UI Id="UserInterface">
      <UIRef Id="WixUI_Minimal" />
    </UI>

  </Product>
</Wix>
